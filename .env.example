# AURÓR · Hub Financeira — variáveis de ambiente
#
# Este arquivo lista apenas NOMES de variáveis previstas. Nenhum valor real.
# Copie para .env.local (ignorado pelo Git) e preencha com valores reais somente localmente.
# Nem todas as variáveis abaixo são necessárias desde o PKG-001 — algumas são
# placeholders para fases futuras e serão confirmadas conforme cada pacote é implementado.

# Supabase (banco, auth, storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Banco de dados (se acesso direto via Postgres for necessário além do client Supabase)
DATABASE_URL=

# IA / classificação (BE-3) — motor híbrido: regras determinísticas primeiro,
# fallback via API da Claude só para fornecedor sem histórico conhecido.
# Server-side apenas — nunca prefixar com NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# Aplicação
APP_URL=
